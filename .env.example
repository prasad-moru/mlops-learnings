# ══════════════════════════════════════════════════════════════
#  MLOps Project — Environment Configuration
#  Copy this file: cp .env.example .env
#  NEVER commit .env to git — it contains real credentials
# ══════════════════════════════════════════════════════════════

# ── MLflow Tracking Server ────────────────────────────────────
# Where the MLflow server is running
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Experiment & Model names ──────────────────────────────────
# Must match the names used in train.py and model_registry.py
EXPERIMENT_NAME=iris_classification
MODEL_NAME=iris_classifier

# Model alias used by api.py and predict.py to load the model.
# model_registry.py sets this alias on the best version.
# Change to "challenger" to test A/B serving.
MODEL_ALIAS=champion

# ── Training ──────────────────────────────────────────────────
RANDOM_SEED=42
ENVIRONMENT=development          # development | staging | production

# ── Model quality gate ────────────────────────────────────────
# model_registry.py will NOT register a model below this threshold.
MIN_ACCURACY=0.90
DRIFT_THRESHOLD=0.05

# ── API Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── PostgreSQL — MLflow backend store ─────────────────────────
# Used by: MLflow server, psycopg2 connection tests
POSTGRES_USER=mlflow_user
POSTGRES_PASSWORD=mlflow_password_2026
POSTGRES_DB=mlflow_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Docker Compose only ───────────────────────────────────────
# Passed as DATABASE_URL into the MLflow container.
# When running locally (not Docker), MLflow uses the
# --backend-store-uri flag directly — this var is not needed.
# When running via docker-compose, this var is injected into
# the mlflow service via environment: DATABASE_URL.
DATABASE_URL=postgresql://mlflow_user:mlflow_password_2026@db/mlflow_db

# ── AWS S3 artifact storage (optional) ───────────────────────
# Uncomment and fill in if storing artifacts in S3 instead of ~/artifacts
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_DEFAULT_REGION=ap-south-1
# MLFLOW_ARTIFACT_ROOT=s3://your-bucket/mlflow-artifacts


============================================================

# ── Add these lines to your existing .env ─────────────────────────────────────
# Monitoring stack — ports for Prometheus, Grafana, ML metrics exporter
API_URI=http://localhost:8000
METRICS_PORT=8001
METRICS_INTERVAL=60
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
